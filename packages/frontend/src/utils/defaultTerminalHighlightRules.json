{
  "rules": [
    {
      "id": "preset-fatal",
      "name": "fatal",
      "enabled": true,
      "pattern": "\\b(FATAL|PANIC|CRITICAL|SEVERE|EMERGENCY|ALERT)\\b",
      "flags": "gi",
      "foreground": "#FF5555",
      "bold": true,
      "underline": false,
      "priority": 220,
      "stopOnMatch": false,
      "presetId": "fatal"
    },
    {
      "id": "preset-error",
      "name": "error",
      "enabled": true,
      "pattern": "(?<![-\\w])(?:ERROR|ERR|FAIL(?:ED|URE)?|ABORT(?:ED)?|CRASH(?:ED)?)(?![-\\w])",
      "flags": "gi",
      "foreground": "#F44747",
      "bold": true,
      "underline": false,
      "priority": 210,
      "stopOnMatch": false,
      "presetId": "error"
    },
    {
      "id": "preset-exception-word",
      "name": "exceptionWord",
      "enabled": true,
      "pattern": "\\b(EXCEPTION|THROWABLE)\\b",
      "flags": "gi",
      "foreground": "#FF6E6E",
      "bold": true,
      "underline": false,
      "priority": 208,
      "stopOnMatch": false,
      "presetId": "exceptionWord"
    },
    {
      "id": "preset-warning",
      "name": "warning",
      "enabled": true,
      "pattern": "(?<![-\\w])(?:WARN(?:ING)?|DEPRECATED|RETRY(?:ING)?|TIMEOUT)(?![-\\w])",
      "flags": "gi",
      "foreground": "#FFB86C",
      "bold": true,
      "underline": false,
      "priority": 200,
      "stopOnMatch": false,
      "presetId": "warning"
    },
    {
      "id": "preset-success",
      "name": "success",
      "enabled": true,
      "pattern": "\\b(SUCCESS|SUCCEEDED|PASS(?:ED)?|OK|DONE|READY|STARTED|RUNNING|COMPLETED)\\b",
      "flags": "g",
      "foreground": "#50FA7B",
      "bold": false,
      "underline": false,
      "priority": 190,
      "stopOnMatch": false,
      "presetId": "success"
    },
    {
      "id": "preset-info",
      "name": "info",
      "enabled": true,
      "pattern": "\\b(INFO|NOTICE)\\b",
      "flags": "gi",
      "foreground": "#8BE9FD",
      "bold": false,
      "underline": false,
      "priority": 180,
      "stopOnMatch": false,
      "presetId": "info"
    },
    {
      "id": "preset-debug",
      "name": "debug",
      "enabled": true,
      "pattern": "\\b(DEBUG|TRACE|VERBOSE)\\b",
      "flags": "gi",
      "foreground": "#6272A4",
      "bold": false,
      "underline": false,
      "priority": 170,
      "stopOnMatch": false,
      "presetId": "debug"
    },
    {
      "id": "preset-timestamp-iso",
      "name": "timestampIso",
      "enabled": true,
      "pattern": "\\b\\d{4}-\\d{2}-\\d{2}[T\\s]\\d{2}:\\d{2}:\\d{2}(?:[.,]\\d{1,9})?(?:Z|[+-]\\d{2}:?\\d{2})?\\b",
      "flags": "g",
      "foreground": "#7A8599",
      "bold": false,
      "underline": false,
      "priority": 165,
      "stopOnMatch": false,
      "presetId": "timestampIso"
    },
    {
      "id": "preset-timestamp-slash",
      "name": "timestampSlash",
      "enabled": true,
      "pattern": "\\b\\d{4}/\\d{1,2}/\\d{1,2}\\s+\\d{1,2}:\\d{2}:\\d{2}(?:[.,]\\d{1,9})?\\b",
      "flags": "g",
      "foreground": "#78869A",
      "bold": false,
      "underline": false,
      "priority": 164,
      "stopOnMatch": false,
      "presetId": "timestampSlash"
    },
    {
      "id": "preset-timestamp-cn",
      "name": "timestampChinese",
      "enabled": true,
      "pattern": "\\b\\d{4}年\\d{1,2}月\\d{1,2}日\\s*\\d{1,2}:\\d{2}:\\d{2}(?:[.,]\\d{1,9})?\\b",
      "flags": "g",
      "foreground": "#768397",
      "bold": false,
      "underline": false,
      "priority": 163,
      "stopOnMatch": false,
      "presetId": "timestampChinese"
    },
    {
      "id": "preset-date-only",
      "name": "dateOnly",
      "enabled": true,
      "pattern": "\\b\\d{4}[-/]\\d{1,2}[-/]\\d{1,2}\\b",
      "flags": "g",
      "foreground": "#5C6B8A",
      "bold": false,
      "underline": false,
      "priority": 80,
      "stopOnMatch": false,
      "presetId": "dateOnly"
    },
    {
      "id": "preset-time-only",
      "name": "timeOnly",
      "enabled": true,
      "pattern": "\\b\\d{1,2}:\\d{2}:\\d{2}(?:[.,]\\d{1,9})?\\b",
      "flags": "g",
      "foreground": "#58677F",
      "bold": false,
      "underline": false,
      "priority": 79,
      "stopOnMatch": false,
      "presetId": "timeOnly"
    },
    {
      "id": "preset-java-thread",
      "name": "javaThread",
      "enabled": true,
      "pattern": "\\[(?:[A-Za-z_$][\\w.$:-]*)(?:-\\d+)+\\]",
      "flags": "g",
      "foreground": "#98C379",
      "bold": false,
      "underline": false,
      "priority": 158,
      "stopOnMatch": false,
      "presetId": "javaThread"
    },
    {
      "id": "preset-root-prompt",
      "name": "rootPrompt",
      "enabled": true,
      "pattern": "^root@[A-Za-z0-9_.-]+(?=[:\\s])",
      "flags": "gm",
      "foreground": "#FF6B6B",
      "bold": true,
      "underline": false,
      "priority": 156,
      "stopOnMatch": false,
      "presetId": "rootPrompt"
    },
    {
      "id": "preset-user-host-prompt",
      "name": "userHostPrompt",
      "enabled": true,
      "pattern": "^(?!root@)[A-Za-z0-9_.-]+@[A-Za-z0-9_.-]+(?=[:\\s])",
      "flags": "gm",
      "foreground": "#7EE787",
      "bold": true,
      "underline": false,
      "priority": 155,
      "stopOnMatch": false,
      "presetId": "userHostPrompt"
    },
    {
      "id": "preset-prompt-path",
      "name": "promptPath",
      "enabled": true,
      "pattern": "(?<=:)(?:~|/)[A-Za-z0-9._~:@%+\\-\\/]*(?=\\s|[$#❯➜])",
      "flags": "g",
      "foreground": "#E5C07B",
      "bold": false,
      "underline": false,
      "priority": 153,
      "stopOnMatch": false,
      "presetId": "promptPath"
    },
    {
      "id": "preset-shell-prompt-symbol",
      "name": "shellPromptSymbol",
      "enabled": true,
      "pattern": "[$#❯➜]\\s",
      "flags": "g",
      "foreground": "#69FF94",
      "bold": true,
      "underline": false,
      "priority": 152,
      "stopOnMatch": false,
      "presetId": "shellPromptSymbol"
    },
    {
      "id": "preset-git-branch-prompt",
      "name": "gitBranchPrompt",
      "enabled": true,
      "pattern": "\\((?:main|master|dev|develop|feature/[A-Za-z0-9._/-]+|fix/[A-Za-z0-9._/-]+|hotfix/[A-Za-z0-9._/-]+|release/[A-Za-z0-9._/-]+)\\)",
      "flags": "g",
      "foreground": "#BD93F9",
      "bold": false,
      "underline": false,
      "priority": 151,
      "stopOnMatch": false,
      "presetId": "gitBranchPrompt"
    },
    {
      "id": "preset-common-command",
      "name": "commonCommand",
      "enabled": true,
      "pattern": "(?<![\\w.])(?:sudo|su|ssh|scp|sftp|rsync|curl|wget|ping|telnet|nc|dig|nslookup|ip|ifconfig|ss|netstat|lsof|ps|top|htop|free|df|du|ls|ll|la|cd|pwd|cat|less|more|tail|head|grep|egrep|fgrep|awk|sed|find|xargs|tar|gzip|gunzip|zip|unzip|chmod|chown|chgrp|mkdir|rmdir|rm|cp|mv|touch|ln|vim|vi|nano|systemctl|journalctl|service|crontab|kill|killall|nohup|screen|tmux|bash|sh|zsh|fish|exit|export|source|alias|history|env|printenv|which|whereis|whoami|hostname|uname|date|echo)(?![\\w.-])",
      "flags": "g",
      "foreground": "#DCDCAA",
      "bold": true,
      "underline": false,
      "priority": 146,
      "stopOnMatch": false,
      "presetId": "commonCommand"
    },
    {
      "id": "preset-devops-command",
      "name": "devopsCommand",
      "enabled": true,
      "pattern": "(?<![\\w.])(?:docker-compose|docker|compose|kubectl|helm|nerdctl|podman|ctr|git|java|mvn|gradle|npm|pnpm|yarn|node|python3|python|pip3|pip|go|rustc|cargo|make|cmake|gcc|g\\+\\+|mysql|redis-cli|psql)(?![\\w.-])",
      "flags": "gi",
      "foreground": "#73D13D",
      "bold": true,
      "underline": false,
      "priority": 147,
      "stopOnMatch": false,
      "presetId": "devopsCommand"
    },
    {
      "id": "preset-git-subcommand",
      "name": "gitSubcommand",
      "enabled": false,
      "pattern": "\\b(add|commit|push|pull|fetch|clone|checkout|switch|branch|merge|rebase|reset|diff|tag|stash|remote|cherry-pick)\\b",
      "flags": "g",
      "foreground": "#C792EA",
      "bold": false,
      "underline": false,
      "priority": 118,
      "stopOnMatch": false,
      "presetId": "gitSubcommand"
    },
    {
      "id": "preset-docker-subcommand",
      "name": "dockerSubcommand",
      "enabled": false,
      "pattern": "\\b(run|exec|build|pull|push|images|ps|restart|stop|start|rm|rmi|volume|network|compose|up|down)\\b",
      "flags": "g",
      "foreground": "#4FC1FF",
      "bold": false,
      "underline": false,
      "priority": 117,
      "stopOnMatch": false,
      "presetId": "dockerSubcommand"
    },
    {
      "id": "preset-kubectl-word",
      "name": "kubectlWord",
      "enabled": false,
      "pattern": "\\b(pod|pods|deploy|deployment|svc|service|ingress|namespace|configmap|secret|node|nodes|describe|apply|delete|get|watch|logs|rollout)\\b",
      "flags": "gi",
      "foreground": "#79A8FF",
      "bold": false,
      "underline": false,
      "priority": 116,
      "stopOnMatch": false,
      "presetId": "kubectlWord"
    },
    {
      "id": "preset-long-option",
      "name": "longOption",
      "enabled": true,
      "pattern": "(^|[\\s=])--[A-Za-z][A-Za-z0-9_-]*(?:=[^\\s\\\"']+)?",
      "flags": "g",
      "foreground": "#F1FA8C",
      "bold": false,
      "underline": false,
      "priority": 140,
      "stopOnMatch": false,
      "presetId": "longOption"
    },
    {
      "id": "preset-short-option",
      "name": "shortOption",
      "enabled": true,
      "pattern": "(^|[\\s=])-[A-Za-z0-9]{1,5}\\b",
      "flags": "g",
      "foreground": "#F6D365",
      "bold": false,
      "underline": false,
      "priority": 139,
      "stopOnMatch": false,
      "presetId": "shortOption"
    },
    {
      "id": "preset-env-assignment",
      "name": "envAssignment",
      "enabled": true,
      "pattern": "\\b[A-Z_][A-Z0-9_]{1,40}=[^\\s;|&]+",
      "flags": "g",
      "foreground": "#4EC9B0",
      "bold": false,
      "underline": false,
      "priority": 138,
      "stopOnMatch": false,
      "presetId": "envAssignment"
    },
    {
      "id": "preset-shell-variable",
      "name": "shellVariable",
      "enabled": true,
      "pattern": "\\$(?:[A-Za-z_][A-Za-z0-9_]*|\\{[A-Za-z_][A-Za-z0-9_]*\\}|\\?|!|\\d+)",
      "flags": "g",
      "foreground": "#40C8AE",
      "bold": false,
      "underline": false,
      "priority": 137,
      "stopOnMatch": false,
      "presetId": "shellVariable"
    },
    {
      "id": "preset-operator",
      "name": "operator",
      "enabled": true,
      "pattern": "(&&|\\|\\||\\||;|>>?|<<?|2>&1|1>&2)",
      "flags": "g",
      "foreground": "#56B6C2",
      "bold": false,
      "underline": false,
      "priority": 136,
      "stopOnMatch": false,
      "presetId": "operator"
    },
    {
      "id": "preset-comment-line",
      "name": "commentLine",
      "enabled": true,
      "pattern": "(^|\\s)#.*$",
      "flags": "gm",
      "foreground": "#6A9955",
      "bold": false,
      "underline": false,
      "priority": 135,
      "stopOnMatch": false,
      "presetId": "commentLine"
    },
    {
      "id": "preset-double-quoted-string",
      "name": "doubleQuotedString",
      "enabled": false,
      "pattern": "\\\"(?:\\\\.|[^\\\"\\\\])*\\\"",
      "flags": "g",
      "foreground": "#CE9178",
      "bold": false,
      "underline": false,
      "priority": 125,
      "stopOnMatch": false,
      "presetId": "doubleQuotedString"
    },
    {
      "id": "preset-single-quoted-string",
      "name": "singleQuotedString",
      "enabled": false,
      "pattern": "'(?:\\\\.|[^'\\\\])*'",
      "flags": "g",
      "foreground": "#D69D85",
      "bold": false,
      "underline": false,
      "priority": 124,
      "stopOnMatch": false,
      "presetId": "singleQuotedString"
    },
    {
      "id": "preset-url",
      "name": "url",
      "enabled": true,
      "pattern": "https?://[^\\s\\\"'<>]+",
      "flags": "gi",
      "foreground": "#61AFEF",
      "bold": false,
      "underline": true,
      "priority": 132,
      "stopOnMatch": false,
      "presetId": "url"
    },
    {
      "id": "preset-linux-path",
      "name": "linuxPath",
      "enabled": true,
      "pattern": "(^|\\s)(?:~|/)[A-Za-z0-9._~:@%+\\-]+(?:/[A-Za-z0-9._~:@%+\\-]+)*",
      "flags": "g",
      "foreground": "#D7BA7D",
      "bold": false,
      "underline": false,
      "priority": 123,
      "stopOnMatch": false,
      "presetId": "linuxPath"
    },
    {
      "id": "preset-windows-path",
      "name": "windowsPath",
      "enabled": true,
      "pattern": "\\b[A-Za-z]:\\\\(?:[^\\\\/:*?\\\"<>|\\r\\n]+\\\\)*[^\\\\/:*?\\\"<>|\\r\\n]*",
      "flags": "g",
      "foreground": "#C5945C",
      "bold": false,
      "underline": false,
      "priority": 122,
      "stopOnMatch": false,
      "presetId": "windowsPath"
    },
    {
      "id": "preset-file-line",
      "name": "fileLine",
      "enabled": true,
      "pattern": "\\b[\\w./\\\\-]+\\.(?:java|js|ts|tsx|jsx|vue|go|py|cs|cpp|c|h|hpp|xml|ya?ml|json|properties|sql|sh|ps1):\\d+(?::\\d+)?\\b",
      "flags": "gi",
      "foreground": "#DCDCAA",
      "bold": false,
      "underline": false,
      "priority": 128,
      "stopOnMatch": false,
      "presetId": "fileLine"
    },
    {
      "id": "preset-ipv4-port",
      "name": "ipv4Port",
      "enabled": true,
      "pattern": "\\b(?:(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)\\.){3}(?:25[0-5]|2[0-4]\\d|1?\\d?\\d):\\d{1,5}\\b",
      "flags": "g",
      "foreground": "#B392F0",
      "bold": false,
      "underline": false,
      "priority": 112,
      "stopOnMatch": false,
      "presetId": "ipv4Port"
    },
    {
      "id": "preset-ipv4",
      "name": "ipv4",
      "enabled": true,
      "pattern": "\\b(?:(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)\\.){3}(?:25[0-5]|2[0-4]\\d|1?\\d?\\d)\\b",
      "flags": "g",
      "foreground": "#B48EFA",
      "bold": false,
      "underline": false,
      "priority": 111,
      "stopOnMatch": false,
      "presetId": "ipv4"
    },
    {
      "id": "preset-ipv6",
      "name": "ipv6",
      "enabled": true,
      "pattern": "\\b(?:[A-Fa-f0-9]{1,4}:){2,7}[A-Fa-f0-9]{1,4}\\b",
      "flags": "g",
      "foreground": "#A78BFA",
      "bold": false,
      "underline": false,
      "priority": 110,
      "stopOnMatch": false,
      "presetId": "ipv6"
    },
    {
      "id": "preset-domain",
      "name": "domain",
      "enabled": true,
      "pattern": "\\b(?:[a-zA-Z0-9-]+\\.)+[a-zA-Z]{2,}(?::\\d{1,5})?\\b",
      "flags": "g",
      "foreground": "#4DB6AC",
      "bold": false,
      "underline": false,
      "priority": 95,
      "stopOnMatch": false,
      "presetId": "domain"
    },
    {
      "id": "preset-size",
      "name": "size",
      "enabled": true,
      "pattern": "\\b\\d+(?:\\.\\d+)?\\s*(?:B|KB|MB|GB|TB|KiB|MiB|GiB|TiB)\\b",
      "flags": "g",
      "foreground": "#D19A66",
      "bold": false,
      "underline": false,
      "priority": 108,
      "stopOnMatch": false,
      "presetId": "size"
    },
    {
      "id": "preset-duration",
      "name": "duration",
      "enabled": true,
      "pattern": "\\b\\d+(?:\\.\\d+)?\\s*(?:ns|μs|us|ms|s|sec|secs|second|seconds|min|mins|h|hr|hrs)\\b",
      "flags": "gi",
      "foreground": "#EBCB8B",
      "bold": false,
      "underline": false,
      "priority": 107,
      "stopOnMatch": false,
      "presetId": "duration"
    },
    {
      "id": "preset-percent",
      "name": "percent",
      "enabled": true,
      "pattern": "\\b\\d+(?:\\.\\d+)?%\\b",
      "flags": "g",
      "foreground": "#F2CC60",
      "bold": false,
      "underline": false,
      "priority": 106,
      "stopOnMatch": false,
      "presetId": "percent"
    },
    {
      "id": "preset-number",
      "name": "number",
      "enabled": true,
      "pattern": "\\b[-+]?\\d+(?:\\.\\d+)?\\b",
      "flags": "g",
      "foreground": "#B5CEA8",
      "bold": false,
      "underline": false,
      "priority": 50,
      "stopOnMatch": false,
      "presetId": "number"
    },
    {
      "id": "preset-http-status-error",
      "name": "httpStatusError",
      "enabled": true,
      "pattern": "\\bHTTP/[0-9.]+\\s+[45][0-9]{2}\\b|\\b[45][0-9]{2}\\s+(?:Error|Failed|Failure|Unauthorized|Forbidden|Not Found|Internal Server Error)\\b",
      "flags": "gi",
      "foreground": "#FF6363",
      "bold": true,
      "underline": false,
      "priority": 134,
      "stopOnMatch": false,
      "presetId": "httpStatusError"
    },
    {
      "id": "preset-http-status-redirect",
      "name": "httpStatusRedirect",
      "enabled": true,
      "pattern": "\\bHTTP/[0-9.]+\\s+3[0-9]{2}\\b|\\b3[0-9]{2}\\s+(?:Moved|Found|Redirect|Not Modified)\\b",
      "flags": "gi",
      "foreground": "#F78C6C",
      "bold": false,
      "underline": false,
      "priority": 133,
      "stopOnMatch": false,
      "presetId": "httpStatusRedirect"
    },
    {
      "id": "preset-http-status-ok",
      "name": "httpStatusOk",
      "enabled": true,
      "pattern": "\\bHTTP/[0-9.]+\\s+2[0-9]{2}\\b|\\b2[0-9]{2}\\s+(?:OK|Created|Accepted|No Content)\\b",
      "flags": "gi",
      "foreground": "#7BD88F",
      "bold": false,
      "underline": false,
      "priority": 132,
      "stopOnMatch": false,
      "presetId": "httpStatusOk"
    },
    {
      "id": "preset-http-method",
      "name": "httpMethod",
      "enabled": true,
      "pattern": "\\b(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)\\b(?=\\s+[/a-zA-Z0-9])",
      "flags": "g",
      "foreground": "#80CBC4",
      "bold": true,
      "underline": false,
      "priority": 131,
      "stopOnMatch": false,
      "presetId": "httpMethod"
    },
    {
      "id": "preset-java-exception",
      "name": "javaException",
      "enabled": true,
      "pattern": "\\b(?:[a-zA-Z_$][\\w$]*\\.)*(?:[A-Z][A-Za-z0-9_$]*)(?:Exception|Error)\\b",
      "flags": "g",
      "foreground": "#FF7B72",
      "bold": true,
      "underline": false,
      "priority": 160,
      "stopOnMatch": false,
      "presetId": "javaException"
    },
    {
      "id": "preset-stacktrace",
      "name": "stackTrace",
      "enabled": true,
      "pattern": "^\\s*at\\s+(?:[a-zA-Z_$][\\w$]*\\.)+[A-Za-z_$][\\w$]*\\([^)]*\\)",
      "flags": "gm",
      "foreground": "#C586C0",
      "bold": false,
      "underline": false,
      "priority": 129,
      "stopOnMatch": false,
      "presetId": "stackTrace"
    },
    {
      "id": "preset-caused-by",
      "name": "causedBy",
      "enabled": true,
      "pattern": "^\\s*Caused by:\\s+.*$",
      "flags": "gmi",
      "foreground": "#FF8080",
      "bold": true,
      "underline": false,
      "priority": 130,
      "stopOnMatch": false,
      "presetId": "causedBy"
    },
    {
      "id": "preset-sql-danger",
      "name": "sqlDanger",
      "enabled": true,
      "pattern": "\\b(DROP|TRUNCATE|DELETE\\s+FROM|UPDATE\\s+\\w+\\s+SET|ALTER|GRANT|REVOKE)\\b",
      "flags": "g",
      "foreground": "#FF5370",
      "bold": true,
      "underline": false,
      "priority": 127,
      "stopOnMatch": false,
      "presetId": "sqlDanger"
    },
    {
      "id": "preset-sql-keyword",
      "name": "sqlKeyword",
      "enabled": true,
      "pattern": "\\b(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE|JOIN|LEFT|RIGHT|INNER|OUTER|ON|GROUP\\s+BY|ORDER\\s+BY|LIMIT|OFFSET|VALUES|SET|AND|OR|IN|LIKE|BETWEEN|IS\\s+NULL|IS\\s+NOT\\s+NULL)\\b",
      "flags": "g",
      "foreground": "#82AAFF",
      "bold": true,
      "underline": false,
      "priority": 101,
      "stopOnMatch": false,
      "presetId": "sqlKeyword"
    },
    {
