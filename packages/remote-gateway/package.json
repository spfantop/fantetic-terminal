{
  "name": "@fantetic-terminal/remote-gateway",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:health",
    "test:health": "esbuild src/test/health.behavior-test.ts --bundle --platform=node --format=esm --outfile=../../.vite-codex-cache/gateway-health.behavior-test.mjs && node ../../.vite-codex-cache/gateway-health.behavior-test.mjs",
    "test:security": "esbuild src/test/security.behavior-test.ts --bundle --platform=node --format=esm --outfile=../../.vite-codex-cache/gateway-security.behavior-test.mjs && node ../../.vite-codex-cache/gateway-security.behavior-test.mjs",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --exec \"ts-node --files src/server.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Unified Remote Desktop Gateway for Fantetic Terminal",
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.2",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "guacamole-lite": "^1.2.0",
    "ws": "^8.21.0"
  }
}
