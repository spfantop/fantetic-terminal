{
  "compilerOptions": {
    "target": "ES2016", 
    "module": "NodeNext", 
    "moduleResolution": "NodeNext", 
    "outDir": "./dist", 
    "rootDir": "./src", 
    "esModuleInterop": true, 
    "forceConsistentCasingInFileNames": true, 
    "strict": true, 
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@fantetic-terminal/contracts": ["../contracts/index.d.ts"]
    }
  },
  "include": ["src/**/*"], 
  "exclude": ["node_modules", "dist", "src/test"] 
}
