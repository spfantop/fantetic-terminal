{
   "name": "@fantetic-terminal/backend",
   "version": "0.1.0",
   "private": true,
   "main": "dist/index.js",
   "scripts": {
      "build": "tsc && copyfiles -u 1 \"src/locales/**/*.json\" dist/src",
      "start": "node dist/index.js",
