      "test:layout-panes": "esbuild src/test/layoutPanes.behavior-test.ts --bundle --platform=node --format=esm --outfile=../../.vite-codex-cache/backend-layoutPanes.behavior-test.mjs && node ../../.vite-codex-cache/backend-layoutPanes.behavior-test.mjs",
