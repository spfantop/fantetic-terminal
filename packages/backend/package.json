      "test:ai-nl2cmd": "esbuild src/test/aiNl2cmd.behavior-test.ts --bundle --platform=node --format=esm --outfile=../../.vite-codex-cache/aiNl2cmd.behavior-test.mjs && node ../../.vite-codex-cache/aiNl2cmd.behavior-test.mjs",
      "test:focus-switcher-config": "esbuild src/test/focusSwitcherConfig.behavior-test.ts --bundle --platform=node --format=esm --outfile=../../.vite-codex-cache/backend-focusSwitcherConfig.behavior-test.mjs && node ../../.vite-codex-cache/backend-focusSwitcherConfig.behavior-test.mjs",
