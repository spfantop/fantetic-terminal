{
  "name": "fantetic-electron-app",
  "version": "2.0.0",
  "description": "Electron application for Fantetic Terminal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test:behavior": "node test/service-readiness.behavior-test.js && node test/windows-packaging.behavior-test.js && node test/security.behavior-test.js && node test/prepare-runtime.behavior-test.js && node test/dev-app.behavior-test.js",
    "sync:version": "node ../build-tools/sync-frontend-version.js",
    "prepare:runtime": "node build-tools/prepare-runtime.js",
    "build": "node ../build-tools/sync-frontend-version.js && npm run prepare:runtime && electron-builder",
    "build:windows": "npm run sync:version && npm run prepare:runtime && electron-builder --win --x64",
    "build:linux": "npm run sync:version && npm run prepare:runtime && electron-builder --linux AppImage deb --x64",
    "build:macos": "npm run build:macos:x64",
    "build:macos:x64": "npm run sync:version && npm run prepare:runtime && electron-builder --mac dmg --x64",
    "build:macos:arm64": "npm run sync:version && npm run prepare:runtime && electron-builder --mac dmg --arm64"
  },
  "keywords": [
    "electron",
    "fantetic",
    "terminal"
  ],
  "author": "",
  "homepage": "https://github.com/spfantop/fantetic-terminal",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "express": "^5.1.0"
  },
  "build": {
    "appId": "com.fantetic.terminal",
    "productName": "Fantetic Terminal",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "security.js",
      "service-readiness.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime/packages",
        "to": "packages",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "../packages/frontend/public/icons/icon-512x512.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "../packages/frontend/public/icons/icon-512x512.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "../packages/frontend/public/icons/icon-512x512.png",
      "maintainer": "Fantetic"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${os}-${arch}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-${os}-${arch}-portable.${ext}"
    }
  }
}
