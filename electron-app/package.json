{
  "name": "fantetic-electron-app",
  "version": "1.5.1",
  "description": "Electron application for Fantetic Terminal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "prepare:runtime": "node build-tools/prepare-runtime.js",
    "build": "node ../build-tools/sync-frontend-version.js && npm run prepare:runtime && electron-builder"
  },
  "keywords": [
    "electron",
    "fantetic",
    "terminal"
  ],
  "author": "",
  "homepage": "https://github.com/spfantop/fantetic-terminal",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "express": "^5.1.0"
  },
  "build": {
    "appId": "com.fantetic.terminal",
    "productName": "Fantetic Terminal",
    "asar": true,
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime/packages",
        "to": "packages",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../packages/frontend/public/icons/icon-512x512.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "../packages/frontend/public/icons/icon-512x512.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "../packages/frontend/public/icons/icon-512x512.png",
      "maintainer": "Fantetic"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
