{
  "name": "fantetic-terminal",
  "version": "2.0.2",
  "main": "index.js",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "node build-tools/test/workspace-test-suite.behavior-test.js && node build-tools/workspace-test-suite.js",
    "build:frontend": "npm --workspace @fantetic-terminal/frontend run build",
    "build:backend": "npm --workspace @fantetic-terminal/backend run build",
    "build:app": "npx cross-env VITE_FANTETIC_APP_MODE=electron npm run build:frontend && npm run build:backend && npm --prefix electron-app run build",
    "test:delivery": "node build-tools/test/delivery-pipeline.behavior-test.js && node build-tools/test/security-scan.behavior-test.js && node build-tools/security-scan.js && node build-tools/test/supply-chain.behavior-test.js",
    "dev:app": "node electron-app/dev-app.js",
    "postinstall": "node build-tools/apply-patches.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spfantop/fantetic-terminal.git"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://github.com/spfantop/fantetic-terminal/issues"
  },
  "homepage": "https://github.com/spfantop/fantetic-terminal#readme",
  "description": "",
  "dependencies": {
    "@types/splitpanes": "1.0.6",
    "archiver-zip-encrypted": "^2.0.0",
    "axios": "^1.18.1",
    "vuedraggable": "^4.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "patch-package": "^8.0.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "sqlite3": "^6.0.1"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
