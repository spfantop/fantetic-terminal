# Docker runtime secrets are generated on first start and saved in ./data/.env.
# Do not add generated values here or commit ./data/.env.

NODE_ENV=production
DEPLOYMENT_MODE=docker
RP_ID=localhost
RP_ORIGIN=http://localhost:18111
CORS_ALLOWED_ORIGINS=

# Web deployments default to one active process per shared data directory.
# Set false only when a separately designed HA topology owns sessions, nonce replay and uploads.
SINGLE_NODE_LOCK_ENABLED=true

# Bastion audit recording. Output is always encrypted; set input to false if policy forbids recording keystrokes.
SESSION_RECORDING_ENABLED=true
SESSION_RECORD_INPUT=true
# Optional capacity controls. Zero disables retention/total-size pruning.
# Active recordings are never pruned. New recordings are skipped when free space is below the threshold.
RECORDING_RETENTION_DAYS=0
RECORDING_MAX_TOTAL_BYTES=0
RECORDING_MIN_FREE_BYTES=536870912

# Optional automated backups. They run only when explicitly enabled.
BACKUP_SCHEDULE_ENABLED=false
BACKUP_INTERVAL_MINUTES=1440
BACKUP_RETENTION_COUNT=14
# Set to /backup-archive only when using docker-compose.backup.yml.
BACKUP_ARCHIVE_PATH=
# Host directory mounted by docker-compose.backup.yml; must be an absolute host path in production.
BACKUP_ARCHIVE_HOST_PATH=

# Optional Prometheus scrape endpoint. When empty, GET /metrics returns 404.
# Set a strong secret and configure the scraper with Authorization: Bearer <value>.
METRICS_TOKEN=
# Readiness fails when free space in backend data directory is below this many bytes.
HEALTH_MIN_FREE_BYTES=104857600
