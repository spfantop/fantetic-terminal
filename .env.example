# Web/Docker production secrets. Never commit real values.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=
# Generate with the same command as SESSION_SECRET. Backend and remote-gateway must share it.
REMOTE_GATEWAY_SHARED_SECRET=

NODE_ENV=production
DEPLOYMENT_MODE=docker
RP_ID=localhost
RP_ORIGIN=http://localhost:18111
CORS_ALLOWED_ORIGINS=
